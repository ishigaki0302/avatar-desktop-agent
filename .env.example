# ─── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=granite4:3b
OLLAMA_TIMEOUT_MS=60000
# 音声向け短文生成。1文 = 最大150トークンで十分
OLLAMA_MAX_PREDICT=150

# ─── Bridge HTTP server ────────────────────────────────────────────────────────
BRIDGE_PORT=3000
# Bind to localhost only (never 0.0.0.0 for security)
BRIDGE_HOST=127.0.0.1

# ─── OpenClaw Gateway (Phase 3) ───────────────────────────────────────────────
# Uncomment and fill when setting up OpenClaw integration
# OPENCLAW_GATEWAY_URL=ws://localhost:7070
# OPENCLAW_API_KEY=your_api_key_here

# ─── UI ───────────────────────────────────────────────────────────────────────
# Typewriter speed in ms per character (35–60)
TYPEWRITER_CHAR_MS=45
# Lipsync toggle interval in ms (100–140)
LIPSYNC_TOGGLE_MS=120
# Lipsync pause durations in ms
LIPSYNC_PAUSE_COMMA_MS=150
LIPSYNC_PAUSE_SENTENCE_MS=400
LIPSYNC_PAUSE_NEWLINE_MS=400
# Motion animation fps (6–12)
MOTION_FPS=8

# ─── Memory ───────────────────────────────────────────────────────────────────
MEMORY_DIR=./storage/memory

# ─── Session logs (JSONL, 1ファイル/セッション) ───────────────────────────────
SESSION_DIR=./storage/sessions

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── UI 確認用スタブモード ────────────────────────────────────────────────────
# STUB_MODE=1 にすると Ollama なしでダミー応答を返す（UI テスト用）
# STUB_MODE=1
